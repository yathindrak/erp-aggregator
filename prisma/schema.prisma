generator client {
    provider      = "prisma-client-js"
    binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

/// Clients managed by the accountant
model Client {
    id               String            @id @default(uuid())
    name             String
    createdAt        DateTime          @default(now())
    updatedAt        DateTime          @updatedAt
    erpConnections   Connection[]
    aggregatedMetric AggregatedMetric?
}

/// Link between a client and their active ERP credentials
model Connection {
    id       String @id @default(uuid())
    clientId String @unique

    /// String instead of Enum to allow dynamic adapter additions without DB migrations
    erpName String // e.g., 'tripletex'

    // Flexible credentials block covering all vendor-specific tokens
    credentials    Json?
    tokenExpiresAt DateTime?
    reauthRequired Boolean   @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    client Client @relation(fields: [clientId], references: [id])
}

/// Computed metrics for the dashboard
model AggregatedMetric {
    id               String    @id @default(uuid())
    clientId         String    @unique
    totalAR          Float
    totalAP          Float
    overdueCount     Int
    overdueTotal     Float
    cashPosition     Float
    lastActivityDate DateTime?
    lastUpdated      DateTime  @default(now())

    client Client @relation(fields: [clientId], references: [id])
}
